{
  "name": "debugsharp",
  "displayName": "DebugSharp",
  "description": "Enhanced C# debugging with IntelliSense expression evaluation, Test Explorer, NuGet & project reference management, and build/test commands with Problems panel integration",
  "version": "1.8.0",
  "publisher": "Ethaewyn",
  "icon": "icon.png",
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Testing"
  ],
  "keywords": [
    "csharp",
    "c#",
    "dotnet",
    ".net",
    "debug",
    "debugger",
    "evaluation",
    "intellisense",
    "nuget",
    "test",
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ethaewyn/debugsharp"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "activationEvents": [
    "onDebug",
    "onLanguage:csharp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugSharp.evaluateExpression",
        "title": "Evaluate Expression",
        "category": "DebugSharp"
      },
      {
        "command": "debugSharp.evaluateInEditor",
        "title": "Evaluate Expression from Editor",
        "category": "DebugSharp"
      },
      {
        "command": "debugSharp.quickLaunch",
        "title": "Quick Launch",
        "category": "DebugSharp",
        "icon": "$(debug-start)"
      },
      {
        "command": "debugSharp.launchProject",
        "title": "Launch Project",
        "category": "DebugSharp",
        "icon": "$(debug-start)"
      },
      {
        "command": "debugSharp.quickBuild",
        "title": "Quick Build Project",
        "category": "DebugSharp",
        "icon": "$(tools)"
      },
      {
        "command": "debugSharp.quickClean",
        "title": "Quick Clean Project",
        "category": "DebugSharp",
        "icon": "$(trash)"
      },
      {
        "command": "debugSharp.quickRebuild",
        "title": "Quick Rebuild Project",
        "category": "DebugSharp",
        "icon": "$(sync)"
      },
      {
        "command": "debugSharp.quickTest",
        "title": "Quick Test Project",
        "category": "DebugSharp",
        "icon": "$(beaker)"
      },
      {
        "command": "debugSharp.generateLaunchConfigurations",
        "title": "Generate Debug Configurations",
        "category": "DebugSharp"
      },
      {
        "command": "debugSharp.manageNugetPackages",
        "title": "Manage NuGet Packages",
        "category": "DebugSharp"
      },
      {
        "command": "debugSharp.addProjectReference",
        "title": "Add Project Reference",
        "category": "DebugSharp"
      },
      {
        "command": "debugSharp.removeProjectReference",
        "title": "Remove Project Reference",
        "category": "DebugSharp"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "debugSharp.manageNugetPackages",
          "when": "resourceExtname == .csproj",
          "group": "nuget@1"
        },
        {
          "command": "debugSharp.addProjectReference",
          "when": "resourceExtname == .csproj",
          "group": "nuget@2"
        },
        {
          "command": "debugSharp.removeProjectReference",
          "when": "resourceExtname == .csproj",
          "group": "nuget@3"
        }
      ],
      "editor/context": [
        {
          "command": "debugSharp.evaluateExpression",
          "when": "debugState == 'stopped'",
          "group": "debug@1"
        }
      ]
    },
    "configuration": {
      "title": "DebugSharp",
      "properties": {
        "debugSharp.suppressFrameworkLogs": {
          "type": "boolean",
          "default": true,
          "description": "Suppress Microsoft/ASP.NET framework logs in the debug console, showing only application logs (similar to Rider's default behavior)."
        },
        "debugSharp.openBrowserOnLaunch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open a browser when launching an ASP.NET web application."
        }
      }
    },
    "keybindings": [
      {
        "command": "debugSharp.evaluateExpression",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorLangId == csharp && debugState == 'stopped'"
      },
      {
        "command": "debugSharp.evaluateInEditor",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "resourceFilename == .vscode-debug-eval.cs"
      },
      {
        "command": "debugSharp.quickLaunch",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q"
      },
      {
        "command": "debugSharp.launchProject",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5"
      },
      {
        "command": "debugSharp.quickBuild",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "debugSharp.quickClean",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "debugSharp.quickRebuild",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "debugSharp.quickTest",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p . && node -e \"require('fs').cpSync('src/ui/panels/templates', 'out/ui/panels/templates', {recursive: true})\""
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.108.1",
    "@vscode/vsce": "^3.7.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
